name:"北京油价查询"
desc:"查询油价"
icon:"https://gitlab.com/lodepuly/iconlibrary/-/raw/main/App_icon/120px/Filen.png"
tiles:
  - name: OilPrice
    interval: 600
    title: '油价'
    icon: 'car'
    backgroundColor: '#00B3FF'
    argument: 'provname=北京'
script-providers:
  OilPrice:
    url: https://fastly.jsdelivr.net/gh/pentiumer/kit@main/oil.js
    
